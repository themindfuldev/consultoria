rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Workspaces: authenticated users can read; only the trainer can write
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && resource == null  // creating
           ? request.resource.data.trainerUid == request.auth.uid
           : resource.data.trainerUid == request.auth.uid;
    }

    // TODO: add per-collection rules for cycles, sessions, feedback before going to production
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
